# ── Discord ────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
SUMMARY_CHANNEL_ID=your_channel_id_here

# ── Line ──────────────────────────────────────────
# Line Developers Console → Messaging API channel 取得
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# ── Anthropic（兩個 bot 共用）────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Notion ───────────────────────────────────────
NOTION_TOKEN=ntn_your_notion_integration_token_here
NOTION_DB_ID=your_notion_database_id_here

# Line bot 庫存查詢用（指向 Notion 的庫存 DB）
INVENTORY_NOTION_DB_ID=your_inventory_database_id_here
INVENTORY_NAME_PROP=品名
INVENTORY_STOCK_PROP=庫存

# ── Google Calendar（私人 iCal 網址）────────────
GCAL_ICAL_URL=https://calendar.google.com/calendar/ical/YOUR_EMAIL/private-XXXXX/basic.ics

# ── 天氣城市 ─────────────────────────────────────
WEATHER_CITY=Kaohsiung

# ── 共用 SQLite 路徑（Docker 內預設 /app/data/bot.db）──
# BOT_DB_PATH=data/bot.db
